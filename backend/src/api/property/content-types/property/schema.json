{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "property",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "string",
      "required": true
    },
    "floors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::floor.floor",
      "mappedBy": "property"
    },
    "ViewsGallery": {
      "type": "component",
      "repeatable": false,
      "component": "shared.gallery"
    },
    "InteriorGallery": {
      "type": "component",
      "repeatable": false,
      "component": "shared.gallery"
    },
    "HeroImage": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "AmenitiesGallery": {
      "type": "component",
      "repeatable": false,
      "component": "shared.gallery"
    },
    "Gallery": {
      "type": "component",
      "repeatable": false,
      "component": "shared.gallery"
    },
    "Address": {
      "type": "text"
    },
    "Builder": {
      "type": "string"
    },
    "Architect": {
      "type": "string"
    },
    "Developer": {
      "type": "string"
    },
    "Facilities": {
      "type": "component",
      "repeatable": false,
      "component": "shared.list"
    },
    "Details": {
      "type": "component",
      "repeatable": false,
      "component": "shared.list"
    },
    "Dates": {
      "type": "component",
      "repeatable": false,
      "component": "shared.list"
    },
    "BookACallLink": {
      "type": "text"
    },
    "MakeAnOfferLink": {
      "type": "text"
    },
    "ProjectWebsiteLink": {
      "type": "string"
    },
    "DealType": {
      "type": "enumeration",
      "enum": [
        "ExclusiveOffMarket",
        "OnMarket"
      ],
      "default": "ExclusiveOffMarket"
    },
    "ListsValues": {
      "type": "text",
      "default": "Extensive Outdoor Living,Lift,Water Views,Rooftop Terraces,Yoga Studio,Indoor Spa,Sauna,Gym,Outdoor Pool,Outdoor Spa,Indoor Pool"
    },
    "StageOfBuild": {
      "type": "enumeration",
      "enum": [
        "PreRelease",
        "UnderConstruction",
        "Completed"
      ],
      "default": "UnderConstruction"
    },
    "Summary": {
      "type": "text"
    },
    "Commission": {
      "type": "decimal",
      "default": 2.2
    },
    "PropertyType": {
      "type": "enumeration",
      "enum": [
        "Land",
        "Residential",
        "Commercial"
      ],
      "default": "Land"
    },
    "PDFImages": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "Downloads": {
      "displayName": "Downloads",
      "type": "component",
      "repeatable": true,
      "component": "shared.downloads"
    },
    "Featured": {
      "type": "boolean",
      "default": false
    },
    "RegisterForUpdatesCode": {
      "type": "text"
    },
    "Brochure": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "HeroImages": {
      "type": "component",
      "repeatable": true,
      "component": "shared.property-hero",
      "required": true
    },
    "PageView": {
      "type": "integer",
      "default": 0
    },
    "MakeOfferButtonClicks": {
      "type": "integer",
      "default": 0
    },
    "DownloadButtonClicks": {
      "type": "integer",
      "default": 0
    },
    "shareToken": {
      "type": "uid",
      "targetField": "Slug"
    },
    "ApprovedUsers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "ApprovedProperties"
    },
    "AccessRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::access-request.access-request",
